: i buffer

#include "klib/klib.crm"

print("is this working?\n\n")

func shell() {
    : buffer
    
    buffer = alloca(20)

    while 1 {
        print("> ")
        if input(buffer, 20) 0 == {
            continue
        }
        print("you said: ")
        print(buffer)
        print("\n")
    }
}

shell()
